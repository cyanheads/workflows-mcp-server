{
  "name": "workflows-mcp-server",
  "version": "0.1.3",
  "description": "Store, query, and create YAML workflow playbooks for LLM agents via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/workflows-mcp-server#readme",
  "repository": "https://github.com/cyanheads/workflows-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "workflows-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/workflows-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
